<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <WarningsAsErrors>nullable</WarningsAsErrors>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);1591</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="DotNetEnv" Version="3.2.0" />
        <PackageReference Include="Grpc.AspNetCore.Server" Version="2.80.0" />
        <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />
        <PackageReference Include="Swashbuckle.AspNetCore" Version="10.2.1" />
    </ItemGroup>

    <ItemGroup>
        <Folder Include="Rest\" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\AIsra.HeuristicLibWrapper\AIsra.HeuristicLibWrapper.csproj" />
        <ProjectReference Include="..\AIsra.HeuristicWeb.Grpc.Core\AIsra.HeuristicWeb.Grpc.Core.csproj" />
    </ItemGroup>

    <PropertyGroup>
        <SolutionDirectory Condition=" '$(SolutionDirectory)' == '' ">$(MSBuildThisFileDirectory)..\</SolutionDirectory>
        <ApiAssembly>$(MSBuildProjectDirectory)\bin\$(Configuration)\net10.0\AIsra.HeuristicWeb.Server.dll</ApiAssembly>
    </PropertyGroup>

    <Target Name="BuildSwaggerFile" AfterTargets="Build" Condition="'$(SKIP_SWAGGER)' == ''">
        <Exec EnvironmentVariables="ASPNETCORE_ENVIRONMENT=Development" Command="dotnet tool restore" />
        <Exec EnvironmentVariables="ASPNETCORE_ENVIRONMENT=Development"
              Command="dotnet tool run swagger tofile --output $(ProjectDir)openapi.json $(ApiAssembly) v1" />
    </Target>

</Project>
