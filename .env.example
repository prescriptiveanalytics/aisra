# Required
OPENROUTER_API_KEY=sk-or-v1-...

# Host Port Mappings
# REDIS_PORT_HOST=6379
# MQTT_PORT_HOST=1883
# SERVER_GRPC_PORT_HOST=5000
# SERVER_REST_PORT_HOST=5081
# AGENT_PORT_HOST=5297
# FRONTEND_PORT_HOST=3000

# Backend Configuration
# CLIENT_TYPE=Lib
# MODEL=openrouter/owl-alpha
# MODEL_ENDPOINT=https://openrouter.ai/api/v1/
# SERVER_ENABLE_HTTPS=false
# AGENT_ENABLE_HTTPS=false

# Frontend Configuration
# URL the browser uses to reach the backend API.
# Use https://localhost:5297 when running the backend with HTTPS (default / IDE).
# Use http://localhost:5297 when running with ENABLE_HTTPS=false (Docker).
# PUBLIC_API_URL=https://localhost:5297
