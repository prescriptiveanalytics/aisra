@startuml

participant "MQTT\nClient" as mqttClient
participant "Redis\nClient" as redis
participant "HeuristicLib\nWrapper" as wrapper
participant "Model\nEvaluator" as eval
participant "MCP\nServer" as mcp
participant "Chat Client\n(LLM)" as chatClient
participant "Frontend" as frontend

?-> mqttClient: Data

mqttClient -> redis: Store data

mqttClient -> eval: Notify new data

eval -> eval: Evaluate model quality

alt Quality below threshold
    eval -> chatClient: Notify agent

    loop While quality below threshold
        chatClient -> mcp: Compute quality
        activate mcp
        mcp -> frontend: Update (Tool Call)
        mcp -> eval: Compute quality
        activate eval
        return Quality
        return Quality

        chatClient -> mcp: Get data
        activate mcp
        mcp -> frontend: Update (Tool Call)
        mcp -> redis: Get data
        activate redis
        return Data
        return Data

        chatClient -> mcp: Retrain residual model
        activate mcp
        mcp -> frontend: Update (Tool Call)
        mcp -> redis: Get data
        activate redis
        return Data
        mcp -> mcp: Calculate residuals
        mcp -> wrapper: Run symbolic regression
        activate wrapper
        return Model
        mcp -> redis: Store model
        return

        chatClient -> frontend: Update (Message)
    end
end

...

frontend -> chatClient: User input
activate chatClient
chatClient -> frontend: Update (Message)
deactivate chatClient

@enduml
